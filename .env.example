# ===== Banco (Neon Postgres) =====
# Pegue em neon.tech > seu projeto > Connection string
DATABASE_URL="postgresql://USER:PASS@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASS@HOST/neondb?sslmode=require"

# ===== Auth.js =====
# Gere com: openssl rand -base64 32
AUTH_SECRET="cole-aqui-um-segredo-aleatorio"
# Em produção, a URL do domínio (ex: https://conectauai.com.br)
AUTH_URL="http://localhost:3000"

# ===== Admin Master (Mateus) — usados só no seed inicial =====
ADMIN_MASTER_EMAIL="mateushope@hotmail.com"
ADMIN_MASTER_PASSWORD="defina-uma-senha-forte"

# ===== E-mail (Resend) — notifica o Mateus a cada novo cadastro =====
RESEND_API_KEY="re_xxxxxxxx"
NOTIFY_EMAIL="eventos@conectauai.com.br"
FROM_EMAIL="Conecta UAI <eventos@conectauai.com.br>"

# ===== Storage de banners (Vercel Blob) =====
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
