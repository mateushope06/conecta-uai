// Conecta UAI — modelo de dados
// Tabelas: users, events, categories, cities, organizers, banners, settings, audit_logs, submissions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // usado pelas migrations no Neon (pooler vs direto)
}

enum Role {
  ADMIN_MASTER // Mateus Hope — único que concede/revoga permissões
  ADMIN        // pode aprovar/recusar eventos
  EDITOR       // pode editar conteúdo
}

enum EventStatus {
  PENDING   // cadastrado, aguardando aprovação
  APPROVED  // publicado na agenda
  REJECTED  // recusado
}

enum Modality {
  PRESENCIAL
  ONLINE
  HIBRIDO
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String?
  role         Role     @default(ADMIN)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  approvedEvents Event[]    @relation("ApprovedBy")
  auditLogs      AuditLog[]

  @@map("users")
}

model City {
  id     String  @id @default(cuid())
  name   String  @unique
  uf     String  @default("MG")
  events Event[]

  @@map("cities")
}

model Category {
  id     String  @id @default(cuid())
  name   String  @unique
  color  String  @default("#0D3B8C") // gradiente/cor do card por categoria
  events Event[]

  @@map("categories")
}

model Organizer {
  id     String  @id @default(cuid())
  name   String  @unique
  events Event[]

  @@map("organizers")
}

model Event {
  id          String      @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  startTime   String?     // "09:00"
  endTime     String?     // "12:00"
  address     String?     // endereço / local
  modality    Modality    @default(PRESENCIAL)
  registerUrl String?     // link de inscrição
  featured    Boolean     @default(false)
  status      EventStatus @default(PENDING)

  cityId      String?
  city        City?       @relation(fields: [cityId], references: [id])
  categoryId  String?
  category    Category?   @relation(fields: [categoryId], references: [id])
  organizerId String?
  organizer   Organizer?  @relation(fields: [organizerId], references: [id])

  banner Banner?

  approvedById String?
  approvedBy   User?   @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  // dados de quem cadastrou
  submitterName  String?
  submitterEmail String?
  submitterPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, date])
  @@map("events")
}

model Banner {
  id        String   @id @default(cuid())
  url       String   // URL no storage (Vercel Blob / Supabase)
  width     Int?
  height    Int?
  event     Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId   String?  @unique
  createdAt DateTime @default(now())

  @@map("banners")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // ex: "EVENT_APPROVED", "USER_GRANTED"
  detail    String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("audit_logs")
}
